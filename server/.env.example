# =============================================================================
# AnxietyWatch Sync Server — Environment Variables
# =============================================================================
# Copy this file to server/.env and replace all placeholder values.
#
#   cp server/.env.example server/.env
#
# IMPORTANT: Never commit server/.env — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# ADMIN_PASSWORD — Login password for the admin web UI at /admin
# -----------------------------------------------------------------------------
# Choose a strong random password. This protects the admin interface where you
# can manage API keys, view synced data, and configure external integrations.
#
# Generate a strong password:
#   python3 -c "import secrets; print(secrets.token_urlsafe(16))"
#
ADMIN_PASSWORD=change-me-to-a-secret

# -----------------------------------------------------------------------------
# SECRET_KEY — Flask session secret + encryption key for stored credentials
# -----------------------------------------------------------------------------
# Used for Flask session cookies and to encrypt sensitive values stored in the
# database (e.g., Walgreens/ResMed passwords configured via the admin UI).
#
# MUST be a long, random string. If you change this after setup, any encrypted
# values in the database will become unreadable and must be re-entered.
#
# Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
SECRET_KEY=change-me-flask-session-secret

# -----------------------------------------------------------------------------
# PostgreSQL credentials
# -----------------------------------------------------------------------------
# These configure the PostgreSQL database used by the sync server.
# If running via docker-compose (recommended), these are used by both the
# Postgres container and the Flask app.
#
# POSTGRES_USER: Database username (default: anxietywatch)
# POSTGRES_PASSWORD: Database password — choose something strong
# POSTGRES_DB: Database name (default: anxietywatch)
# DATABASE_URL: Full connection string — update the password to match above
#
# If you change POSTGRES_PASSWORD, also update it in DATABASE_URL.
#
POSTGRES_USER=anxietywatch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=anxietywatch
DATABASE_URL=postgresql://anxietywatch:change-me@anxietywatch-db:5432/anxietywatch

# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY — Claude API key for the AI analysis admin page (optional)
# -----------------------------------------------------------------------------
# Required only if you want to run AI-generated analyses from the admin UI at
# /admin/analysis. Without this, the analysis page will flash an error but the
# rest of the server works normally.
#
# Obtain a key from https://console.anthropic.com/settings/keys
#
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# GRAPHQL_API_KEY — ResMed myAir API key (optional)
# -----------------------------------------------------------------------------
# Required only if you want to sync CPAP data from ResMed's cloud service.
# To obtain this key:
#   1. Log in to https://myair.resmed.com in your browser
#   2. Open browser Developer Tools (F12) → Network tab
#   3. Look for GraphQL requests to the myAir API
#   4. Copy the x-api-key header value from any request
#
# If you don't use a ResMed CPAP machine, leave this blank or remove this line.
#
GRAPHQL_API_KEY=

# -----------------------------------------------------------------------------
# ResMed myAir login credentials (NOT stored here)
# -----------------------------------------------------------------------------
# Your ResMed username/password are configured via the admin UI at:
#   /admin/settings/resmed
#
# They are stored encrypted in the database using SECRET_KEY above,
# never in this file or in environment variables.

# -----------------------------------------------------------------------------
# GENIUS_API_TOKEN — Genius API token for song search/metadata (optional)
# -----------------------------------------------------------------------------
# Required for the song tracking feature. Obtain a token from:
#   https://genius.com/api-clients
#
# GENIUS_API_TOKEN=

# -----------------------------------------------------------------------------
# MUSIXMATCH_API_KEY — Musixmatch API key for lyrics fallback (optional)
# -----------------------------------------------------------------------------
# Used when Genius lyrics scraping fails. Obtain a key from:
#   https://developer.musixmatch.com
#
# MUSIXMATCH_API_KEY=
