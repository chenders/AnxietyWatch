# Admin UI login password. Choose a strong random password.
ADMIN_PASSWORD=change-me-to-a-secret

# Flask session secret + encryption key for stored credentials (e.g., myAir password).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-flask-session-secret

# PostgreSQL credentials
POSTGRES_USER=anxietywatch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=anxietywatch
DATABASE_URL=postgresql://anxietywatch:change-me@anxietywatch-db:5432/anxietywatch

# ResMed myAir credentials are configured via the admin UI at /admin/settings/resmed
# (stored encrypted in the database, not in this file).
