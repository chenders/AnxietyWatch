# GitHub Actions Runner Configuration
# Copy to /opt/github-runners-anxietywatch/.env and fill in values.
#
# ACCESS_TOKEN: Fine-grained GitHub PAT scoped to chenders/AnxietyWatch
#               with Administration read/write permission. 90-day expiry.
# REPO_URL:     The repository this runner serves.

ACCESS_TOKEN=YOUR_FINE_GRAINED_GITHUB_PAT_HERE
REPO_URL=https://github.com/chenders/AnxietyWatch
