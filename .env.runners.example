# =============================================================================
# GitHub Actions Self-Hosted Runner Configuration
# =============================================================================
# Copy to /opt/github-runners-anxietywatch/.env and fill in values.
# Used by docker-compose.runners.yml to register a self-hosted runner.
#
# Only needed if you host your own GitHub Actions runner for CI/CD.
# If you use GitHub-hosted runners, you can ignore this file entirely.
# =============================================================================

# -----------------------------------------------------------------------------
# ACCESS_TOKEN — Fine-grained GitHub Personal Access Token
# -----------------------------------------------------------------------------
# Required to register the runner with your GitHub repository.
#
# To create one:
#   1. Go to https://github.com/settings/tokens?type=beta
#   2. Click "Generate new token"
#   3. Set a descriptive name (e.g., "AnxietyWatch CI Runner")
#   4. Under "Repository access", select "Only select repositories"
#      and choose your AnxietyWatch fork
#   5. Under "Permissions" → "Repository permissions":
#      - Administration: Read and write
#   6. Set expiration (90 days recommended — you'll need to rotate it)
#   7. Click "Generate token" and paste the value below
#
ACCESS_TOKEN=YOUR_FINE_GRAINED_GITHUB_PAT_HERE

# -----------------------------------------------------------------------------
# REPO_URL — The GitHub repository URL this runner serves
# -----------------------------------------------------------------------------
# Change this to your own fork's URL.
#
REPO_URL=https://github.com/YOUR_USERNAME/AnxietyWatch
